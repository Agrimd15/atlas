{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c 'import yfinance' 2>/dev/null || pip3 install -q yfinance requests >/dev/null 2>&1 || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/atlas_autopublish.sh\""
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "ramp-data": {
      "type": "http",
      "url": "https://mcp.ramp.com/ramp-data/anthropic/mcp"
    }
  }
}
